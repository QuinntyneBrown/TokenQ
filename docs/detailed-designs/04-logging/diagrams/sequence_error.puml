@startuml sequence_error
!theme plain
skinparam sequenceMessageAlign center

title Failure Path with Logging

participant "Handler" as H
participant "Generator" as G
participant "FileWriter" as FW
participant "ILogger" as L
participant "stderr" as Err

== Invalid name (validation failure) ==

H -> G : Render("1Foo")
G --> H : throw InvalidNameException(message)

H -> L : LogError(message)
L -> Err : "fail: <message>"
note right of L
  exactly one Error log
  per failure
  exit code = 1
end note

== Unhandled exception ==

H -> FW : Write(...)
FW --> H : throw NullReferenceException(...)

H -> L : LogError("Unexpected internal error")
L -> Err : "fail: Unexpected internal error"

alt verbose flag set
    H -> Err : ex.ToString() written directly
    note right
      raw stack trace bypasses ILogger
      so it never appears in the
      normal log stream
    end note
end

H --> H : return 2

@enduml
